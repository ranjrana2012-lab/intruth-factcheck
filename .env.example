# ──────────────────────────────────────────────────────────────────────────────
# InTruth FactCheck — environment variables. Copy to `.env` and fill in.
# `.env` is gitignored — NEVER commit real keys.
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM (used for claim extraction + verdict synthesis) ─────────────────────
# Default: Ollama Cloud (subscription). Also works with local Ollama, Anthropic, or OpenAI.
OLLAMA_BASE_URL=https://www.intruth-factcheck.example   # ← replace with your Ollama Cloud endpoint
OLLAMA_API_KEY=oll_YourOllamaCloudKeyHere
LLM_MODEL=qwen2.5:7b                                    # default model for claim extraction + verdicts

# Optional cloud fallbacks (only used if you switch provider in config.win.yaml)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Web search / evidence retrieval ────────────────────────────────────────
# Tavily — quick start, no Docker. Get a key at https://tavily.com
TAVILY_API_KEY=tvly-YourTavilyKeyHere

# SearXNG — private/self-hosted. Leave URL empty to disable; set if you run it via Docker.
SEARXNG_URL=                                        # e.g. http://localhost:8080

# ─── Deepgram (ONLY if you keep the original extension's cloud STT path) ─────
# The native engine uses local faster-whisper and does NOT need this.
DEEPGRAM_API_KEY=

# ─── Engine runtime ─────────────────────────────────────────────────────────
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8765
# Where captured audio is transcribed. faster-whisper auto-detects CUDA, falls back to CPU.
ASR_DEVICE=auto                                     # auto | cuda | cpu
ASR_MODEL=small                                     # tiny | base | small | medium | large-v3
VAD_THRESHOLD=0.5                                   # Silero VAD sensitivity (0-1)
